<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <PublishProtocol>FileSystem</PublishProtocol>
    <SolutionRoot Condition="Exists('$(MSBuildProjectDirectory)\CodexHelper.slnx')">$(MSBuildProjectDirectory)\</SolutionRoot>
    <SolutionRoot Condition="'$(SolutionRoot)' == '' And Exists('$(MSBuildProjectDirectory)\..\CodexHelper.slnx')">$(MSBuildProjectDirectory)\..\</SolutionRoot>
    <SolutionRoot Condition="'$(SolutionRoot)' == '' And '$(SolutionDir)' != '' And '$(SolutionDir)' != '*Undefined*'">$(SolutionDir)</SolutionRoot>
    <SolutionRoot Condition="'$(SolutionRoot)' == ''">$(MSBuildThisFileDirectory)..\..\..\</SolutionRoot>
    <PublishDir>$(SolutionRoot)artifacts\publish\win-x64-singlefile-framework\</PublishDir>
    <PublishUrl>$(SolutionRoot)artifacts\publish\win-x64-singlefile-framework\</PublishUrl>
    <PublishSingleFile>true</PublishSingleFile>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
  </PropertyGroup>
</Project>
