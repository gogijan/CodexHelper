<Window x:Class="CodexHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CodexHelper.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="650"
        Width="980"
        MinHeight="650"
        MinWidth="880"
        Icon="Assets/AppIcon.ico"
        Background="{StaticResource AppBackgroundBrush}"
        Loaded="Window_Loaded"
        Closed="Window_Closed">
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="58" />
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="{Binding ElevateText}"
                        Command="{Binding ElevateCommand}"
                        ToolTip="{Binding ElevateToolTipText}"
                        ToolTipService.ShowOnDisabled="True"
                        Margin="0,0,4,0" />
                <Button Grid.Column="1"
                        Content="{Binding ArchiveText}"
                        Command="{Binding ArchiveCommand}"
                        ToolTip="{Binding ArchiveToolTipText}"
                        ToolTipService.ShowOnDisabled="True" />
                <Button Grid.Column="2"
                        Content="{Binding ClearSelectionText}"
                        Command="{Binding ClearSelectionCommand}"
                        ToolTip="{Binding ClearSelectionToolTipText}"
                        ToolTipService.ShowOnDisabled="True" />
                <TextBlock Grid.Column="3"
                           Text="{Binding SelectedSummary}"
                           VerticalAlignment="Center"
                           Margin="4,0,0,0"
                           Foreground="{StaticResource MutedTextBrush}"
                           ToolTip="{Binding SelectedSummaryToolTipText}" />

                <Border Grid.Column="4"
                        Padding="8,3"
                        Margin="12,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="#FEF3C7"
                        BorderBrush="#F59E0B"
                        BorderThickness="1"
                        CornerRadius="7"
                        ToolTip="{Binding ReadOnlyModeToolTipText}"
                        Visibility="{Binding IsReadOnlyMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding ReadOnlyModeText}"
                               FontSize="11.5"
                               FontWeight="SemiBold"
                               Foreground="#92400E" />
                </Border>

                <Button Grid.Column="5"
                        Width="32"
                        Height="32"
                        MinWidth="32"
                        MinHeight="32"
                        Padding="0"
                        Command="{Binding DiagnosticsCommand}"
                        ToolTip="{Binding DiagnosticsToolTipText}"
                        ToolTipService.ShowOnDisabled="True"
                        AutomationProperties.Name="{Binding DiagnosticsText}"
                        Margin="4,0">
                    <Viewbox Width="16"
                             Height="16"
                             Stretch="Uniform">
                        <Canvas Width="24"
                                Height="24">
                            <Path Data="M12,20 C8.7,20 6,17.3 6,14 L6,11 C6,8.8 7.8,7 10,7 L14,7 C16.2,7 18,8.8 18,11 L18,14 C18,17.3 15.3,20 12,20 Z M12,20 L12,11 M8,2 L10,4 M16,2 L14,4 M9,7 L9,6 C9,4.3 10.3,3 12,3 C13.7,3 15,4.3 15,6 L15,7 M6.5,9 C4.6,8.8 3,7.1 3,5 M6,13 L2,13 M3,21 C3,18.9 4.7,17.1 6.8,17 M17.5,9 C19.4,8.8 21,7.1 21,5 M18,13 L22,13 M17.2,17 C19.3,17.1 21,18.9 21,21"
                                  Fill="Transparent"
                                  Stroke="{StaticResource TextBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" />
                        </Canvas>
                    </Viewbox>
                </Button>

                <Button Grid.Column="6"
                        Width="32"
                        Height="32"
                        MinWidth="32"
                        MinHeight="32"
                        Padding="0"
                        Margin="4,0"
                        Command="{Binding RefreshCommand}"
                        ToolTip="{Binding RefreshToolTipText}"
                        ToolTipService.ShowOnDisabled="True">
                    <Viewbox Width="15"
                             Height="15"
                             Stretch="Uniform">
                        <Canvas Width="24"
                                Height="24">
                            <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4C7.58,4 4,7.58 4,12C4,16.42 7.58,20 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.82,16.33 14.6,18 12,18C8.69,18 6,15.31 6,12C6,8.69 8.69,6 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                                  Fill="{StaticResource TextBrush}" />
                        </Canvas>
                    </Viewbox>
                </Button>
                <ComboBox Grid.Column="7"
                          Width="132"
                          MinWidth="0"
                          ItemsSource="{Binding ThreadFilterOptions}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Code"
                          SelectedValue="{Binding SelectedThreadFilterCode, Mode=TwoWay}"
                          VerticalAlignment="Center"
                          ToolTip="{Binding ThreadFilterToolTipText}"
                          Margin="4,0,8,0" />
                <ComboBox Grid.Column="8"
                          Width="82"
                          MinWidth="0"
                          ItemsSource="{Binding LanguageOptions}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Code"
                          SelectedValue="{Binding SelectedLanguageCode, Mode=TwoWay}"
                          VerticalAlignment="Center"
                          ToolTip="{Binding LanguageToolTipText}" />
            </Grid>
        </Border>

        <Grid x:Name="MainContentGrid"
              Grid.Row="1"
              SizeChanged="MainContentGrid_SizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ProjectPaneColumn" Width="390" MinWidth="300" />
                <ColumnDefinition x:Name="SplitterColumn" Width="12" />
                <ColumnDefinition x:Name="ThreadPreviewColumn" Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="12,12,0,12"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid Margin="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="4" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          x:Name="TreeSearchBoxHost"
                          Height="28"
                          Margin="8,8,8,4"
                          VerticalAlignment="Top">
                        <TextBox Height="28"
                                 MinHeight="28"
                                 Padding="4,3,30,3"
                                 FontSize="12"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center" />
                        <TextBlock Text="{Binding SearchTextLabel}"
                                   Margin="9,0,30,0"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding SearchText}" Value="" />
                                                <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=TreeSearchBoxHost}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Width="22"
                                Height="22"
                                MinWidth="22"
                                MinHeight="22"
                                Padding="0"
                                Margin="0,0,4,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Command="{Binding ClearSearchCommand}"
                                Visibility="{Binding HasSearchText, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Path Width="7"
                                  Height="7"
                                  Data="M 0 0 L 8 8 M 8 0 L 0 8"
                                  Stretch="Fill"
                                  Stroke="{StaticResource MutedTextBrush}"
                                  StrokeEndLineCap="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeThickness="1.8" />
                        </Button>
                    </Grid>

                    <Border Grid.Row="1"
                            Height="4"
                            Margin="8,0,8,0"
                            Background="Transparent">
                        <ProgressBar Height="4"
                                     IsIndeterminate="True"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="{StaticResource PrimaryBrush}"
                                     Visibility="{Binding IsTreeLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </Border>

                    <Grid Grid.Row="2"
                          x:Name="ProjectTreeClipHost"
                          SizeChanged="RoundedClipHost_SizeChanged">
                        <TreeView x:Name="ProjectTree"
                              ItemsSource="{Binding Projects}"
                              BorderThickness="0"
                              Margin="0,0,3,3"
                              Padding="6,2,2,6"
                              ClipToBounds="True"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              PreviewKeyDown="ProjectTree_PreviewKeyDown"
                              SelectedItemChanged="ProjectTree_SelectedItemChanged">
                        <TreeView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </TreeView.ItemsPanel>
                        <TreeView.Resources>
                            <Style x:Key="ProjectExpandToggleStyle" TargetType="ToggleButton">
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="IsTabStop" Value="False" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Width="16"
                                                    Height="18"
                                                    Background="Transparent">
                                                <Path x:Name="Arrow"
                                                      Width="6"
                                                      Height="8"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 6 4 L 0 8 Z"
                                                      Fill="{StaticResource MutedTextBrush}"
                                                      RenderTransformOrigin="0.5,0.5" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Arrow" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="90" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Arrow" Property="Fill" Value="{StaticResource PrimaryBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>

                            <Style TargetType="TreeViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                <Setter Property="IsSelected" Value="{Binding IsTreeSelected, Mode=TwoWay}" />
                                <Setter Property="Padding" Value="2,1" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TreeViewItem">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Border x:Name="ItemBorder"
                                                        Grid.Row="0"
                                                        Background="Transparent"
                                                        BorderBrush="Transparent"
                                                        BorderThickness="1"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter x:Name="PART_Header"
                                                                      ContentSource="Header"
                                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                                                </Border>
                                                <ItemsPresenter x:Name="ItemsHost"
                                                                Grid.Row="1"
                                                                Margin="18,0,0,0" />
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsExpanded" Value="False">
                                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                                                </Trigger>
                                                <Trigger Property="HasItems" Value="False">
                                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#F8FAFC" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#EEF2FF" />
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#B9C7F7" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>

                            <HierarchicalDataTemplate DataType="{x:Type vm:ProjectNodeViewModel}"
                                                      ItemsSource="{Binding Threads}">
                                <Border Padding="6,3"
                                        Margin="0"
                                        Background="Transparent"
                                        CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsThreeState="True"
                                                  IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                  Focusable="False"
                                                  IsTabStop="False"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,4,0" />
                                        <ToggleButton Grid.Column="1"
                                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=TreeViewItem}, Mode=TwoWay}"
                                                      Margin="0,0,3,0"
                                                      VerticalAlignment="Center"
                                                      Style="{StaticResource ProjectExpandToggleStyle}" />
                                        <StackPanel Grid.Column="2">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="VerticalAlignment" Value="Top" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasFullPath}" Value="False">
                                                            <Setter Property="VerticalAlignment" Value="Center" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="{Binding Header}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="None"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding FullPath}"
                                                       FontSize="11"
                                                       TextTrimming="None"
                                                       TextWrapping="Wrap"
                                                       Visibility="{Binding HasFullPath, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                       Foreground="{StaticResource MutedTextBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </HierarchicalDataTemplate>

                            <DataTemplate DataType="{x:Type vm:ThreadNodeViewModel}">
                                <Border Padding="6,3"
                                        Margin="0"
                                        Background="Transparent"
                                        CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                  Focusable="False"
                                                  IsTabStop="False"
                                                  VerticalAlignment="Top"
                                                  Margin="0,2,7,0" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="12.5"
                                                       TextTrimming="None"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding UpdatedAtText}"
                                                       FontSize="11"
                                                       TextTrimming="None"
                                                       Foreground="{StaticResource MutedTextBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    Margin="8,1,0,0"
                                                    VerticalAlignment="Top">
                                            <Border Padding="6,2"
                                                    Background="#DBEAFE"
                                                    CornerRadius="7"
                                                    ToolTip="{Binding OpenInCodexText}"
                                                    Visibility="{Binding IsOpenInCodex, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="O"
                                                           FontSize="10.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextBrush}" />
                                            </Border>
                                            <Border Padding="6,2"
                                                    Margin="4,0,0,0"
                                                    Background="{StaticResource ArchivedBadgeBrush}"
                                                    CornerRadius="7"
                                                    ToolTip="{Binding StateText}"
                                                    Visibility="{Binding IsArchived, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="A"
                                                           FontSize="10.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextBrush}" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </TreeView.Resources>
                    </TreeView>
                </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="12"
                          HorizontalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          Background="Transparent" />

            <Grid x:Name="ThreadPreviewPane"
                  Grid.Column="2"
                  MinWidth="550"
                  Margin="0,12,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Margin="0,0,10,6">
                                        <Run Text="{Binding DetailsText, Mode=OneWay}" /><Run Text=":" />
                                    </TextBlock>
                                    <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding SelectedThread.Name, Mode=OneWay}" FontWeight="SemiBold" Style="{StaticResource InfoValueTextBoxStyle}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,10,6">
                                        <Run Text="{Binding ProjectText, Mode=OneWay}" /><Run Text=":" />
                                    </TextBlock>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SelectedThread.Cwd, Mode=OneWay}" Style="{StaticResource InfoValueTextBoxStyle}" Margin="0,0,24,6" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,10,6">
                                        <Run Text="{Binding StateText, Mode=OneWay}" /><Run Text=":" />
                                    </TextBlock>
                                    <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding SelectedThread.StateText, Mode=OneWay}" Style="{StaticResource InfoValueTextBoxStyle}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,10,0">
                                        <Run Text="{Binding ThreadIdText, Mode=OneWay}" /><Run Text=":" />
                                    </TextBlock>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SelectedThread.Id, Mode=OneWay}" FontFamily="Consolas" FontSize="12" Style="{StaticResource InfoValueTextBoxStyle}" Margin="0,0,24,0" />
                                    <TextBlock Grid.Row="2" Grid.Column="2" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,10,0">
                                        <Run Text="{Binding UpdatedText, Mode=OneWay}" /><Run Text=":" />
                                    </TextBlock>
                                    <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding SelectedThread.UpdatedAtText, Mode=OneWay}" Style="{StaticResource InfoValueTextBoxStyle}" Margin="0" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,10,0">
                                        <Run Text="{Binding ModelEffortLabelText, Mode=OneWay}" /><Run Text=":" />
                                    </TextBlock>
                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding ModelEffortText, Mode=OneWay}" FontFamily="Consolas" FontSize="12" Style="{StaticResource InfoValueTextBoxStyle}" Margin="0,6,24,0" />
                                    <TextBlock Grid.Row="3" Grid.Column="2" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,10,0">
                                        <Run Text="{Binding TimestampText, Mode=OneWay}" /><Run Text=":" />
                                    </TextBlock>
                                    <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding ThreadTimestampText, Mode=OneWay}" Style="{StaticResource InfoValueTextBoxStyle}" Margin="0,6,0,0" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <DockPanel>
                        <Border DockPanel.Dock="Top"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="0,0,0,1"
                                CornerRadius="8,8,0,0"
                                Padding="12,12,12,8">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="DialogTabButton"
                                             Content="{Binding DialogTabText}"
                                             GroupName="ThreadPreviewTabs"
                                             IsChecked="True"
                                             Checked="PreviewTab_Checked"
                                             Style="{StaticResource PillTabRadioButtonStyle}" />
                                <RadioButton x:Name="DeveloperInstructionsTabButton"
                                             Content="{Binding DeveloperInstructionsTabText}"
                                             GroupName="ThreadPreviewTabs"
                                             Checked="PreviewTab_Checked"
                                             Style="{StaticResource PillTabRadioButtonStyle}" />
                                <RadioButton x:Name="UserInstructionsTabButton"
                                             Content="{Binding UserInstructionsTabText}"
                                             GroupName="ThreadPreviewTabs"
                                             Checked="PreviewTab_Checked"
                                             Style="{StaticResource PillTabRadioButtonStyle}" />
                                <RadioButton x:Name="ParametersTabButton"
                                             Content="{Binding ParametersTabText}"
                                             GroupName="ThreadPreviewTabs"
                                             Checked="PreviewTab_Checked"
                                             Style="{StaticResource PillTabRadioButtonStyle}" />
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,0,2,2">
                            <FlowDocumentScrollViewer x:Name="ConversationViewer"
                                                      IsToolBarVisible="False"
                                                      Margin="0,0,2,0"
                                                      Zoom="100"
                                                      VerticalScrollBarVisibility="Auto"
                                                      Visibility="{Binding IsChecked, ElementName=DialogTabButton, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <FlowDocumentScrollViewer x:Name="DeveloperInstructionsViewer"
                                                      IsToolBarVisible="False"
                                                      Margin="0,0,2,0"
                                                      Zoom="100"
                                                      VerticalScrollBarVisibility="Auto"
                                                      Visibility="{Binding IsChecked, ElementName=DeveloperInstructionsTabButton, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <FlowDocumentScrollViewer x:Name="UserInstructionsViewer"
                                                      IsToolBarVisible="False"
                                                      Margin="0,0,2,0"
                                                      Zoom="100"
                                                      VerticalScrollBarVisibility="Auto"
                                                      Visibility="{Binding IsChecked, ElementName=UserInstructionsTabButton, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <TreeView ItemsSource="{Binding ThreadParameterNodes}"
                                      x:Name="ParametersTree"
                                      BorderThickness="0"
                                      Margin="0,0,2,0"
                                      Padding="16,12"
                                      ScrollViewer.CanContentScroll="True"
                                      VirtualizingStackPanel.IsVirtualizing="True"
                                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                                      KeyDown="ParametersTree_KeyDown"
                                      Visibility="{Binding IsChecked, ElementName=ParametersTabButton, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TreeView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel />
                                    </ItemsPanelTemplate>
                                </TreeView.ItemsPanel>
                                <TreeView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{Binding PlacementTarget.DataContext.CopyText, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Click="CopyParameterMenuItem_Click" />
                                    </ContextMenu>
                                </TreeView.ContextMenu>
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                        <Setter Property="Margin" Value="0,1" />
                                        <EventSetter Event="PreviewMouseRightButtonDown" Handler="ParameterTreeItem_PreviewMouseRightButtonDown" />
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.Resources>
                                    <HierarchicalDataTemplate DataType="{x:Type vm:JsonTreeNodeViewModel}"
                                                              ItemsSource="{Binding Children}">
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Name}"
                                                       FontFamily="Consolas"
                                                       FontSize="12.5"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextBrush}"
                                                       VerticalAlignment="Center" />
                                            <Border Grid.Column="1"
                                                    Margin="8,0,8,0"
                                                    Padding="6,1"
                                                    Background="#F1F5F9"
                                                    BorderBrush="#D8DEE8"
                                                    BorderThickness="1"
                                                    CornerRadius="7"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Type}"
                                                           FontSize="10.5"
                                                           Foreground="{StaticResource MutedTextBrush}" />
                                            </Border>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Value}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding HasValue, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </Grid>
                                    </HierarchicalDataTemplate>
                                </TreeView.Resources>
                            </TreeView>
                            <Border Background="#DFFFFFFF"
                                    Panel.ZIndex="10"
                                    Visibility="{Binding IsThreadLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Border Width="240"
                                        Padding="20,18"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource PanelBrush}"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding LoadingSessionText}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,12"
                                                   FontWeight="SemiBold" />
                                        <ProgressBar Height="4"
                                                     IsIndeterminate="True" />
                                    </StackPanel>
                                </Border>
                            </Border>
                        </Grid>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,0">
            <Grid>
                <TextBlock Text="{Binding StatusText}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}" />
                <ProgressBar HorizontalAlignment="Right"
                             Width="150"
                             Height="4"
                             IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                             VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>
